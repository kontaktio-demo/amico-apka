{
  "name": "amico-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AMICO – system do zarzadzania pracownia kamieniarska (PWA + aplikacja desktopowa)",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "desktop": "npm run build && node scripts/desktop.cjs",
    "desktop:build": "npm run build && electron-builder --win",
    "desktop:ikona": "node scripts/ikona.cjs"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@supabase/supabase-js": "^2.110.2",
    "clsx": "^2.1.1",
    "idb-keyval": "^6.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.47",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
